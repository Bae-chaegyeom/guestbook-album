# ── 데이터베이스 ──────────────────────────────────────────────────────────────
DATABASE_URL="mysql://user:password@localhost:3306/guestbook_album"

# ── 서버 ─────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Sweetbook Book Print API ──────────────────────────────────────────────────
# 파트너 포털(https://partner.sweetbook.com)에서 발급받은 API 키를 입력하세요.
SWEETBOOK_API_KEY=SB_your_api_key_here

# 환경 선택: sandbox (테스트, 실제 인쇄 없음) | live (실제 주문 처리)
SWEETBOOK_ENV=sandbox
